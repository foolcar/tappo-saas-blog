# Cloudflare Pages _redirects
# NOTE: Order matters — first match wins. Specific rules must come before catch-all.

# Redirect old GitHub Pages paths to new domain
/tappo-saas-blog/*    /:splat    301

# Redirect bare /blog/ and /en/blog/ listing pages to homepages
/blog/       /     301
/en/blog/    /en/  301

# SPA fallback (last resort) — keep Astro routing working
/*    /index.html   404
