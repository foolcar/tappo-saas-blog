---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    // Replace / with - in URL slug (e.g. "UI/UX" → "UI-UX")
    params: { tag: tag.replace(/\//g, '-') },
  }));
};

// Build reverse lookup (slug → original tag)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))];
const slugToTag = new Map(allTags.map((t) => [t.replace(/\//g, '-'), t]));

const tagSlug = Astro.params.tag;
const tag = slugToTag.get(tagSlug) ?? tagSlug;

const posts = allPosts
  .filter((p) => p.data.tags.includes(tag))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function estimateReadingTime(text: string): number {
  const cjkChars = (text.match(/[\u4e00-\u9fff\u3400-\u4dbf]/g) || []).length;
  const words = text.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil((cjkChars + words) / 400));
}

const categoryColors: Record<string, string> = {
  'POS選購': '#b85c3a',
  '全球市場': '#5a8a6a',
  '國際化': '#7c5aa8',
  '支付整合': '#c4893a',
  '合規挑戰': '#c44a4a',
  '產品設計': '#b84a7a',
  '團隊管理': '#4a6ab8',
};
---

<BlogLayout
  title={`標籤「${tag}」 — 餐飲SaaS出海指南`}
  description={`瀏覽標籤為「${tag}」的所有文章 — 餐飲SaaS出海實戰經驗，從中國香港走向全球市場。`}
  type="website"
>
  <!-- Header -->
  <section class="border-b border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
      <a
        href={`${import.meta.env.BASE_URL}tags`}
        class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)]
               hover:text-[var(--color-accent)] transition-colors mb-6"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        所有標籤
      </a>

      <div class="flex items-center gap-3 mb-3">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold
                     bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
          #{tag}
        </span>
        <span class="text-sm text-[var(--color-text-muted)]">
          {posts.length} 篇文章
        </span>
      </div>

      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text)]">
        {tag}
      </h1>
    </div>
  </section>

  <!-- Article List -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    {
      posts.length === 0 ? (
        <div class="text-center py-24">
          <p class="text-xl font-semibold text-[var(--color-text)] mb-2">此標籤暫無文章</p>
          <p class="text-sm text-[var(--color-text-muted)] mb-8">
            標籤「{tag}」下暫無已發布的文章
          </p>
          <a
            href={import.meta.env.BASE_URL}
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium
                   bg-[var(--color-accent)] text-white hover:opacity-90 transition-opacity"
          >
            ← 返回首頁
          </a>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 gap-6">
          {posts.map((post) => {
            const catColor = categoryColors[post.data.category] || '#6b6560';
            return (
              <article
                class="group bg-[var(--color-surface)] rounded-xl border border-[var(--color-border)]
                       hover:border-[var(--color-accent-dim)] hover:shadow-md
                       transition-all duration-300"
              >
                <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="block p-5 sm:p-6 h-full flex flex-col">
                  <div class="flex items-center gap-3 mb-3">
                    <span
                      class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold shrink-0"
                      style={`background-color: ${catColor}15; color: ${catColor}`}
                    >
                      {post.data.category}
                    </span>
                    <span class="text-xs text-[var(--color-text-muted)]">
                      {estimateReadingTime(post.body)} 分鐘
                    </span>
                  </div>

                  <h3 class="text-lg font-bold text-[var(--color-text)]
                             group-hover:text-[var(--color-accent)] transition-colors duration-200
                             leading-snug mb-2 flex-1">
                    {post.data.title}
                  </h3>

                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3 line-clamp-2">
                    {post.data.description}
                  </p>

                  <div class="flex flex-wrap gap-2 mb-3">
                    {post.data.tags.map(t => (
                      <span class={`text-xs px-2 py-0.5 rounded bg-[var(--color-bg)]
                                    ${t === tag ? 'text-[var(--color-accent)] font-medium' : 'text-[var(--color-text-muted)]'}`}>
                        {t}
                      </span>
                    ))}
                  </div>

                  <time datetime={post.data.date.toISOString().split('T')[0]} class="text-xs text-[var(--color-text-muted)]">
                    {post.data.date.toLocaleDateString('zh-Hant', {
                      year: 'numeric', month: 'long', day: 'numeric',
                    })}
                  </time>
                </a>
              </article>
            );
          })}
        </div>
      )
    }
  </section>
</BlogLayout>
