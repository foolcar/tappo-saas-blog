---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);

// Build tag frequency map
const tagMap = new Map<string, number>();
posts.forEach((p) => {
  p.data.tags.forEach((tag) => {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  });
});

// Sort by frequency desc
const sortedTags = [...tagMap.entries()]
  .sort((a, b) => b[1] - a[1]);
---

<BlogLayout
  title="所有標籤"
  description="依標籤瀏覽所有文章 — 餐飲SaaS出海實戰經驗，從中國香港走向全球市場。"
  type="website"
>
  <!-- Header ───────────────────────────────────── -->
  <section class="border-b border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
      <a
        href={import.meta.env.BASE_URL}
        class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)]
               hover:text-[var(--color-accent)] transition-colors mb-6"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        返回首頁
      </a>

      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-3">
        文章標籤
      </h1>

      <p class="text-base text-[var(--color-text-muted)] leading-relaxed">
        共 {sortedTags.length} 個標籤，依出現頻率排序
      </p>
    </div>
  </section>

  <!-- Tag Cloud ────────────────────────────────── -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-wrap gap-3">
      {sortedTags.map(([tag, count]) => {
        const size = count >= 3 ? 'text-base px-4 py-2' : count >= 2 ? 'text-sm px-3 py-1.5' : 'text-xs px-2.5 py-1';
        // Tag slug: replace / with - for URL routing
        const tagSlug = tag.replace(/\//g, '-');
        return (
          <a
            href={`${import.meta.env.BASE_URL}tags/${tagSlug}`}
            class={`${size} rounded-lg font-medium border border-[var(--color-border)]
                    hover:border-[var(--color-accent-dim)] hover:text-[var(--color-accent)]
                    hover:shadow-sm hover:-translate-y-0.5
                    transition-all duration-200 inline-flex items-center gap-2
                    text-[var(--color-text-muted)] bg-[var(--color-surface)]`}
          >
            {tag}
            <span class="text-xs opacity-50">{count}</span>
          </a>
        );
      })}
    </div>
  </section>
</BlogLayout>
