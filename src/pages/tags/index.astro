---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const tagCounts = new Map<string, number>();
for (const p of allPosts) {
  for (const t of p.data.tags) {
    tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
  }
}
const sortedTags = [...tagCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
const maxCount = Math.max(...tagCounts.values());
---

<BlogLayout
  title="標籤總覽"
  description="瀏覽所有文章標籤 — 餐飲SaaS出海實戰經驗分類索引"
  type="website"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">標籤總覽</h1>
    <p class="text-lg text-gray-600 mb-10">
      共 {tagCounts.size} 個標籤，{allPosts.length} 篇文章
    </p>

    <div class="flex flex-wrap gap-3">
      {sortedTags.map(([tag, count]) => {
        const scale = 0.6 + (count / maxCount) * 0.4;
        const tagSlug = tag.replace(/\//g, '-');
        return (
          <a
            href={`${import.meta.env.BASE_URL}tags/${tagSlug}/`}
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-gray-200 bg-white
                   hover:border-blue-300 hover:shadow-sm hover:text-blue-600 transition-all duration-200"
          >
            <span
              class="text-gray-700 hover:text-blue-600 transition-colors"
              style={`font-size: ${(scale * 0.875).toFixed(2)}rem`}
            >
              {tag}
            </span>
            <span class="text-xs text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded-full">
              {count}
            </span>
          </a>
        );
      })}
    </div>
  </div>
</BlogLayout>
