---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const wordCount = post.body?.match(/[\u4e00-\u9fff]|[a-zA-Z]+/g)?.length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 400));

// Get related posts (same category, excluding current)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((p) => p.data.category === post.data.category && p.slug !== post.slug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const categoryColors: Record<string, string> = {
  'POS選購': '#b85c3a',
  '全球市場': '#5a8a6a',
  '國際化': '#7c5aa8',
  '支付整合': '#c4893a',
  '合規挑戰': '#c44a4a',
  '產品設計': '#b84a7a',
  '團隊管理': '#4a6ab8',
};
const catColor = categoryColors[post.data.category] || '#6b6560';
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  date={post.data.date}
  updated={post.data.updated}
  category={post.data.category}
  tags={post.data.tags}
  slug={post.slug}
  image={post.data.image || '/og-default.svg'}
  wordCount={wordCount}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <!-- 文章頭部 ──────────────────────────────── -->
    <header class="mb-10 sm:mb-12">
      <!-- Category + Tags -->
      <div class="flex flex-wrap items-center gap-2 mb-5">
        <a
          href={`${import.meta.env.BASE_URL}category/${encodeURIComponent(post.data.category)}`}
          class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold
                 hover:opacity-80 transition-opacity"
          style={`background-color: ${catColor}15; color: ${catColor}`}
        >
          {post.data.category}
        </a>
        {post.data.tags.map((tag) => (
          <a
            href={`${import.meta.env.BASE_URL}tags/${tag.replace(/\//g, '-')}`}
            class="text-xs px-2.5 py-1 rounded-full bg-[var(--color-bg)]
                   text-[var(--color-text-muted)] hover:text-[var(--color-accent)]
                   transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>

      <!-- Title -->
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text)]
                 leading-tight mb-4">
        {post.data.title}
      </h1>

      <!-- Description -->
      <p class="text-lg text-[var(--color-text-muted)] leading-relaxed mb-5 max-w-2xl">
        {post.data.description}
      </p>

      <!-- Meta line -->
      <div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-[var(--color-text-muted)]
                  pb-6 border-b border-[var(--color-border)]">
        <time datetime={post.data.date.toISOString().split('T')[0]}>
          發佈於 {post.data.date.toLocaleDateString('zh-Hant', {
            year: 'numeric', month: 'long', day: 'numeric',
          })}
        </time>
        {post.data.updated && post.data.updated > post.data.date && (
          <time datetime={post.data.updated.toISOString().split('T')[0]}>
            · 更新於 {post.data.updated.toLocaleDateString('zh-Hant', {
              year: 'numeric', month: 'long', day: 'numeric',
            })}
          </time>
        )}
        <span>· {readingTime} 分鐘閱讀</span>
        <span>· {wordCount.toLocaleString()} 字</span>
      </div>
    </header>

    <!-- 文章內容 ───────────────────────────────── -->
    <div class="prose">
      <Content />
    </div>

    <!-- 文章頁尾 ───────────────────────────────── -->
    <footer class="mt-16 sm:mt-20 pt-8 border-t border-[var(--color-border)]">

      <!-- Author bio -->
      <div class="bg-[var(--color-accent-soft)] rounded-xl p-6 sm:p-8 mb-12">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full flex items-center justify-center text-lg font-bold shrink-0
                      text-white"
               style={`background-color: ${catColor}`}>
            公
          </div>
          <div>
            <p class="font-bold text-[var(--color-text)] mb-1">阿公</p>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              20 多年中港兩地工作，30 多年互聯網產品探索經驗。<br/>
              熱衷分享餐飲科技出海的實戰見解。
            </p>
          </div>
        </div>
      </div>

      <!-- Related articles -->
      {relatedPosts.length > 0 && (
        <div class="mb-12">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)] mb-4">
            相關文章
          </p>
          <div class="grid sm:grid-cols-2 gap-4">
            {relatedPosts.map((rp) => (
              <a
                href={`${import.meta.env.BASE_URL}blog/${rp.slug}`}
                class="group block p-4 sm:p-5 rounded-xl border border-[var(--color-border)]
                       hover:border-[var(--color-accent-dim)] hover:shadow-sm
                       bg-[var(--color-surface)] transition-all duration-200"
              >
                <h4 class="font-semibold text-[var(--color-text)]
                           group-hover:text-[var(--color-accent)] transition-colors
                           leading-snug mb-1 text-sm">
                  {rp.data.title}
                </h4>
                <p class="text-xs text-[var(--color-text-muted)] line-clamp-2">
                  {rp.data.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Back to home -->
      <nav>
        <a
          href={import.meta.env.BASE_URL}
          class="inline-flex items-center gap-1.5 text-sm font-medium
                 text-[var(--color-text-muted)] hover:text-[var(--color-accent)]
                 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          返回文章列表
        </a>
      </nav>
    </footer>
  </article>
</BlogLayout>
