---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blogEn', ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categoryMap: Record<string, string> = {
  'POS Purchasing': '#3B82F6',
  'Global Markets': '#10B981',
  'Internationalization': '#8B5CF6',
  'Payment Integration': '#F59E0B',
  'Compliance': '#EF4444',
  'Product Design': '#EC4899',
  'Team Management': '#6366F1',
};
---

<BlogLayout
  title="F&B SaaS Going Global Guide"
  description="Real-world insights on taking F&B SaaS products from Hong Kong to global markets. Covering POS selection, market strategy, internationalization, payment integration, compliance, and team management."
  type="website"
  locale="en"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-50 via-white to-emerald-50 border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-blue-600 tracking-wider uppercase mb-4">
          Real Battles · Deep Insights
        </p>
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight mb-6">
          F&B SaaS <span class="text-blue-600">Going Global</span> Guide
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 leading-relaxed">
          From Hong Kong to the world — sharing real-world experience on taking F&B SaaS
          products global. Covering POS selection, market strategy, technical architecture,
          payment integration, compliance, and team management across borders.
        </p>
      </div>
    </div>
  </section>

  <!-- Article List -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">
      Latest Articles ({sortedPosts.length})
    </h2>

    <div class="grid gap-8">
      {
        sortedPosts.length > 0 ? sortedPosts.map((post) => {
          const category = post.data.category;
          const catColor = categoryMap[category] || '#6B7280';
          return (
            <article class="group bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-lg transition-all duration-300 overflow-hidden">
              <a href={`/en/blog/${post.slug}`} class="block p-6 sm:p-8">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-3">
                  <h3 class="text-xl sm:text-2xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug">
                    {post.data.title}
                  </h3>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium shrink-0"
                     style={`background-color: ${catColor}15; color: ${catColor}`}>
                    {category}
                  </span>
                </div>

                <p class="text-gray-600 leading-relaxed mb-4">
                  {post.data.description}
                </p>

                <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
                  <time datetime={post.data.date.toISOString().split('T')[0]}>
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  {
                    post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {post.data.tags.map(tag => (
                          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{tag}</span>
                        ))}
                      </div>
                    )
                  }
                </div>
              </a>
            </article>
          );
        }) : (
          <div class="text-center py-12 text-gray-500">
            <p class="text-lg">English articles coming soon!</p>
            <p class="mt-2 text-sm">Check back later or browse the <a href="/" class="text-blue-600 hover:underline">Chinese version</a>.</p>
          </div>
        )
      }
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-50 border-t border-gray-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">
        Got F&B SaaS going-global experience to share?
      </h2>
      <p class="text-gray-600 mb-8 max-w-xl mx-auto">
        This is an open knowledge base. If you're also building in the F&B tech space,
        let's connect and exchange ideas.
      </p>
      <a
        href="https://github.com/foolcar/tappo-saas-blog"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-gray-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-800 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </section>
</BlogLayout>
