---
import BlogLayout from '../../layouts/BlogLayout.astro';
---

<BlogLayout
  title="About"
  description="Ah Gung has 20+ years working across Hong Kong and China, 30+ years in internet product design. This blog documents real-world experience taking F&B SaaS from Hong Kong to global markets."
  type="website"
  locale="en"
  alternateUrl="https://blog.foolcar.cc/about/"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-8">About</h1>

    <!-- Author -->
    <div class="bg-white rounded-xl border border-gray-200 p-8 mb-10">
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <div class="w-20 h-20 rounded-full bg-blue-600 text-white flex items-center justify-center text-3xl font-bold shrink-0">
          公
        </div>
        <div>
          <h2 class="text-xl font-bold text-gray-900 mb-2">Ah Gung (阿公)</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            20+ years in Hong Kong and China across Internet, mobile APP,
            From leading engineering teams at major Hong Kong internet companies
            to building digital products for the F&B industry — I've been on both sides
            of the table.
          </p>
          <p class="text-gray-600 leading-relaxed">
            F&B technology is in my DNA. Over the years I've experienced the full spectrum —
            from helping cha chaan tengs digitize their operations, to architecting
            large-scale ordering platforms, to taking SaaS products across borders.
          </p>
        </div>
      </div>
    </div>

    <!-- About this blog -->
    <div class="bg-blue-50 rounded-xl p-8 mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">About This Blog</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        <strong>F&B SaaS Going Global Guide</strong> is a knowledge base built from
        real battles, not textbooks. Each article addresses a specific challenge
        you'll face when taking a restaurant tech product overseas:
      </p>
      <ul class="space-y-2 text-gray-600">
        <li class="flex items-start gap-2">
          <span class="text-blue-500 mt-1 shrink-0">→</span>
          <span><strong>Market mapping</strong> — Which markets to enter first and why</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-500 mt-1 shrink-0">→</span>
          <span><strong>Product localization</strong> — POS design across different F&B cultures</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-500 mt-1 shrink-0">→</span>
          <span><strong>Payment integration</strong> — Octopus, Stripe, GrabPay, and beyond</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-500 mt-1 shrink-0">→</span>
          <span><strong>Compliance</strong> — GDPR, PDPA, and local F&B regulations</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-500 mt-1 shrink-0">→</span>
          <span><strong>i18n & team</strong> — From Cantonese to 11 languages, remote teams across time zones</span>
        </li>
      </ul>
    </div>

    <!-- Contact -->
    <div class="text-center p-8 bg-gray-50 rounded-xl border border-gray-200">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Let's Connect</h2>
      <p class="text-gray-600 mb-6">
        Have questions, insights, or experiences to share about F&B SaaS going global?
        Reach out — I'd love to hear from you.
      </p>
      <div class="flex justify-center gap-4">
        <a
          href="https://github.com/foolcar/tappo-saas-blog"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/ravicli/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</BlogLayout>
