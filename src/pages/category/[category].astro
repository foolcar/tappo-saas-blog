---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((cat) => ({
    params: { category: cat },
  }));
};

const { category } = Astro.params;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter((p) => p.data.category === category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryMap: Record<string, { color: string; emoji: string; desc: string }> = {
  'POS選購':   { color: '#2563EB', emoji: '🖥️',  desc: '如何在港澳市場選擇合適的餐飲 POS 系統？功能對比、價格分析、實施經驗。' },
  '全球市場':  { color: '#059669', emoji: '🌏',  desc: '餐飲 SaaS 出海策略：東南亞、歐美、中東等市場機遇與挑戰。' },
  '國際化':    { color: '#7C3AED', emoji: '🌐',  desc: '多語言、多幣種、多時區 — 餐飲 SaaS 產品的國際化改造實戰。' },
  '支付整合':  { color: '#D97706', emoji: '💳',  desc: '跨國支付通道對接：Stripe、AlipayHK、PayMe 等實戰筆記。' },
  '合規挑戰':  { color: '#DC2626', emoji: '🛡️',  desc: 'GDPR、PDPO、數據跨境傳輸 — 出海路上的法規合規實戰。' },
  '產品設計':  { color: '#DB2777', emoji: '🎨',  desc: '從用戶研究到產品迭代，餐飲 SaaS 的產品設計思維與方法。' },
  '團隊管理':  { color: '#4F46E5', emoji: '👥',  desc: '跨境遠端團隊協作、招聘、文化建設的實戰經驗。' },
  '數位營銷':  { color: '#0891B2', emoji: '📈',  desc: '從 Google Maps 到本地平台，餐飲店鋪的數位引流與顧客增長實戰。' },
};

const cat = categoryMap[category] || { color: '#6B7280', emoji: '📂', desc: `瀏覽所有「${category}」相關文章。` };
const otherCategories = Object.entries(categoryMap).filter(([c]) => c !== category);

// Compute reading stats
function estimateReadTime(body: string): number {
  const words = body.match(/[\u4e00-\u9fff]|[a-zA-Z]+/g)?.length ?? 0;
  return Math.max(1, Math.ceil(words / 400));
}
---

<BlogLayout
  title={`「${category}」文章列表 — 餐飲SaaS出海指南`}
  description={cat.desc}
  type="website"
  breadcrumbs={[
    { name: '首頁', url: 'https://blog.foolcar.cc/' },
    { name: category },
  ]}
>
  <!-- Category Hero -->
  <div class="relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style={`background-color: ${cat.color}`}></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14 relative">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
        <a href={`${import.meta.env.BASE_URL}`} class="hover:text-blue-600 transition-colors">首頁</a>
        <svg class="w-3 h-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="font-medium" style={`color: ${cat.color}`}>{category}</span>
      </nav>

      <!-- Header -->
      <div class="flex items-start gap-4 mb-4">
        <span class="text-4xl sm:text-5xl leading-none">{cat.emoji}</span>
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{category}</h1>
          <p class="text-gray-400 mt-1">共 {posts.length} 篇文章</p>
        </div>
      </div>
      <p class="text-gray-600 mt-4 max-w-xl leading-relaxed">{cat.desc}</p>

      <!-- Accent line -->
      <div class="mt-6 w-16 h-1 rounded-full" style={`background-color: ${cat.color}`}></div>
    </div>
  </div>

  <!-- Article List -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    {
      posts.length === 0 ? (
        <div class="text-center py-20 bg-white rounded-xl border border-dashed border-gray-200">
          <p class="text-4xl mb-4">📭</p>
          <p class="text-gray-500 mb-4">此分類暫無文章，敬請期待。</p>
          <a href={`${import.meta.env.BASE_URL}`} class="text-sm font-medium hover:underline" style={`color: ${cat.color}`}>← 返回首頁</a>
        </div>
      ) : (
        <div class="space-y-5">
          {posts.map((post, i) => {
            const postDate = post.data.date.toLocaleDateString('zh-Hant', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            const readMin = post.body ? estimateReadTime(post.body) : 1;

            return (
              // Article card
              <article class="group bg-white rounded-xl border border-gray-200 hover:border-gray-300 hover:shadow-md transition-all duration-250 overflow-hidden"
                       style={i === 0 ? `border-left: 4px solid ${cat.color};` : ''}>
                <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="block p-5 sm:p-6">
                  {/* Title + meta row */}
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
                    <h2 class="text-lg sm:text-xl font-bold text-gray-900 group-hover:transition-colors leading-snug"
                        style={`--hover-color: ${cat.color}`}>
                      {post.data.title}
                    </h2>
                    <time class="shrink-0 text-xs text-gray-400 whitespace-nowrap pt-1"
                          datetime={post.data.date.toISOString().split('T')[0]}>
                      {postDate}
                    </time>
                  </div>

                  {/* Description */}
                  <p class="text-gray-600 text-sm sm:text-base leading-relaxed mb-3 line-clamp-2">
                    {post.data.description}
                  </p>

                  {/* Footer row */}
                  <div class="flex items-center justify-between gap-3">
                    <div class="flex items-center gap-2 text-xs text-gray-400">
                      <span class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        {readMin} 分鐘閱讀
                      </span>
                      <span class="text-gray-200">|</span>
                      <span>{post.data.tags.length} 個標籤</span>
                    </div>

                    <span class="inline-flex items-center gap-1 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-200"
                          style={`color: ${cat.color}`}>
                      閱讀全文
                      <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </span>
                  </div>

                  {/* Tags pill strip */}
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-3 pt-3 border-t border-gray-50">
                      {post.data.tags.slice(0, 4).map((tag) => (
                        <a href={`${import.meta.env.BASE_URL}tags/${tag.replace(/\//g, '-')}/`}
                           onclick="event.stopPropagation()"
                           class="text-xs px-2 py-0.5 rounded-full bg-gray-50 text-gray-500 hover:bg-gray-100 transition-colors">
                          #{tag}
                        </a>
                      ))}
                    </div>
                  )}
                </a>
              </article>
            );
          })}
        </div>
      )
    }

    <!-- Other Categories -->
    <div class="mt-16 pt-10 border-t border-gray-200">
      <div class="flex items-center gap-3 mb-5">
        <h3 class="text-sm font-semibold text-gray-700">瀏覽其他主題</h3>
        <div class="flex-1 h-px bg-gray-100"></div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {otherCategories.map(([c, info]) => (
          <a href={`${import.meta.env.BASE_URL}category/${encodeURIComponent(c)}/`}
             class="group flex items-center gap-2.5 p-3 rounded-lg border border-gray-200 hover:border-gray-300 hover:shadow-sm transition-all duration-200">
            <span class="text-xl shrink-0">{info.emoji}</span>
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-700 group-hover:text-gray-900 transition-colors truncate">{c}</p>
              <p class="text-xs text-gray-400 truncate">{info.desc.slice(0, 20)}…</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BlogLayout>
