---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((cat) => ({
    params: { category: cat },
  }));
};

const { category } = Astro.params;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter((p) => p.data.category === category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryMap: Record<string, { color: string; emoji: string; desc: string }> = {
  'POS選購':   { color: '#2563EB', emoji: '🖥️',  desc: '如何在港澳市場選擇合適的餐飲 POS 系統？功能對比、價格分析、實施經驗。' },
  '全球市場':  { color: '#059669', emoji: '🌏',  desc: '餐飲 SaaS 出海策略：東南亞、歐美、中東等市場機遇與挑戰。' },
  '國際化':    { color: '#7C3AED', emoji: '🌐',  desc: '多語言、多幣種、多時區 — 餐飲 SaaS 產品的國際化改造實戰。' },
  '支付整合':  { color: '#D97706', emoji: '💳',  desc: '跨國支付通道對接：Stripe、AlipayHK、PayMe 等實戰筆記。' },
  '合規挑戰':  { color: '#DC2626', emoji: '🛡️',  desc: 'GDPR、PDPO、數據跨境傳輸 — 出海路上的法規合規實戰。' },
  '產品設計':  { color: '#DB2777', emoji: '🎨',  desc: '從用戶研究到產品迭代，餐飲 SaaS 的產品設計思維與方法。' },
  '團隊管理':  { color: '#4F46E5', emoji: '👥',  desc: '跨境遠端團隊協作、招聘、文化建設的實戰經驗。' },
};

const cat = categoryMap[category] || { color: '#6B7280', emoji: '📂', desc: `瀏覽所有「${category}」相關文章。` };
const otherCategories = Object.entries(categoryMap).filter(([c]) => c !== category);
const pageTitle = `「${category}」文章列表`;
const pageDesc = cat.desc;

function tint(hex: string, opacity: number): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r}, ${g}, ${b}, ${opacity})`;
}

function readingTime(text: string): string {
  const chars = text.replace(/\s/g, '').length;
  const mins = Math.max(1, Math.round(chars / 300));
  return `${mins} 分鐘`;
}
---

<BlogLayout
  title={`${pageTitle} — 餐飲SaaS出海指南`}
  description={pageDesc}
  type="website"
>
  <!-- ═══════════ Compact Header — 精簡索引頭 ═══════════ -->
  <section class="relative border-b bg-white" style={`border-color: ${tint(cat.color, 0.15)}`}>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Breadcrumb + Category badge -->
      <div class="flex items-center gap-3 mb-4 flex-wrap">
        <a href={`${import.meta.env.BASE_URL}`}
           class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-gray-600 transition-colors group">
          <svg class="w-3.5 h-3.5 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          首頁
        </a>
        <span class="text-gray-300 text-sm" aria-hidden="true">/</span>
        <span
          class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium"
          style={`background: ${tint(cat.color, 0.1)}; color: ${cat.color}`}
        >
          <span class="text-xs leading-none">{cat.emoji}</span>
          {category}
        </span>
      </div>

      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2">
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-gray-900">
            {category}
            <span class="text-gray-400 font-normal text-base ml-2">{posts.length} 篇</span>
          </h1>
          <p class="text-sm text-gray-500 mt-1.5 max-w-lg leading-relaxed">{cat.desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ Article Index — 文章列表 ═══════════ -->
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    {
      posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-gray-400 mb-4">此分類暫無文章，敬請期待。</p>
          <a href={`${import.meta.env.BASE_URL}`}
             class="text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors">← 返回首頁</a>
        </div>
      ) : (
        <div class="space-y-5">
          {posts.map((post) => {
            const bodyText = post.body || '';
            const readTime = readingTime(bodyText);
            const postDate = post.data.date.toLocaleDateString('zh-Hant', {
              month: 'short', day: 'numeric',
            });
            return (
              <article
                class="group relative bg-white rounded-lg border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all duration-200"
                style={`border-left: 3px solid ${tint(cat.color, 0.25)}`}
              >
                <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="block pl-5 pr-5 py-4 sm:pl-6 sm:pr-6 sm:py-5">
                  <div class="flex items-start justify-between gap-3">
                    <div class="flex-1 min-w-0">
                      <h2 class="text-base sm:text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug line-clamp-1">
                        {post.data.title}
                      </h2>
                      <p class="text-sm text-gray-500 mt-1 line-clamp-1 leading-relaxed">
                        {post.data.description}
                      </p>
                    </div>
                    <time datetime={post.data.date.toISOString().split('T')[0]}
                          class="shrink-0 text-xs text-gray-400 whitespace-nowrap mt-0.5">
                      {postDate}
                    </time>
                  </div>

                  <div class="flex flex-wrap items-center gap-3 mt-2.5">
                    <span class="inline-flex items-center gap-1 text-xs text-gray-400">
                      <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      {readTime}
                    </span>
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="text-xs text-gray-400 bg-gray-50 px-1.5 py-0.5 rounded">
                        {tag}
                      </span>
                    ))}
                    {post.data.tags.length > 3 && (
                      <span class="text-xs text-gray-300">+{post.data.tags.length - 3}</span>
                    )}
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )
    }
  </main>

  <!-- ═══════════ 瀏覽其他主題 ═══════════ -->
  <section class="border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-3">其他主題</h3>
      <div class="flex flex-wrap gap-2">
        {otherCategories.map(([c, info]) => (
          <a
            href={`${import.meta.env.BASE_URL}category/${encodeURIComponent(c)}`}
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium border transition-colors hover:shadow-sm"
            style={`border-color: ${tint(info.color, 0.2)}; color: ${info.color}; background: ${tint(info.color, 0.03)}`}
          >
            <span>{info.emoji}</span>
            {c}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ CTA ═══════════════ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-14 text-center">
    <div class="rounded-xl px-6 py-8" style={`background: ${tint(cat.color, 0.03)}`}>
      <p class="text-sm text-gray-500 mb-4">有餐飲SaaS出海的經驗想分享？歡迎交流討論。</p>
      <div class="flex justify-center gap-3">
        <a href="https://github.com/foolcar/tappo-saas-blog" target="_blank" rel="noopener noreferrer"
           class="text-xs font-medium text-gray-500 hover:text-gray-700 transition-colors underline underline-offset-2">
          GitHub
        </a>
        <a href={`${import.meta.env.BASE_URL}`}
           class="text-xs font-medium text-gray-500 hover:text-gray-700 transition-colors underline underline-offset-2">
          全部文章
        </a>
      </div>
    </div>
  </section>
</BlogLayout>
