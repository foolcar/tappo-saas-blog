---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((cat) => ({
    params: { category: cat },
  }));
};

const { category } = Astro.params;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter((p) => p.data.category === category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryMap: Record<string, string> = {
  'POS選購': '#3B82F6',
  '全球市場': '#10B981',
  '國際化': '#8B5CF6',
  '支付整合': '#F59E0B',
  '合規挑戰': '#EF4444',
  '產品設計': '#EC4899',
  '團隊管理': '#6366F1',
};

const categoryDesc: Record<string, string> = {
  'POS選購': '如何在港澳市場選擇合適的餐飲 POS 系統？功能對比、價格分析、實施經驗。',
  '全球市場': '餐飲 SaaS 出海策略：東南亞、歐美、中東等市場機遇與挑戰。',
  '國際化': '多語言、多幣種、多時區 — 餐飲 SaaS 產品的國際化改造實戰。',
  '支付整合': '跨國支付通道對接：Stripe、AlipayHK、PayMe 等實戰筆記。',
  '合規挑戰': 'GDPR、PDPO、數據跨境傳輸 — 出海路上的法規合規實戰。',
  '產品設計': '從用戶研究到產品迭代，餐飲 SaaS 的產品設計思維與方法。',
  '團隊管理': '跨境遠端團隊協作、招聘、文化建設的實戰經驗。',
};

const catColor = categoryMap[category] || '#6B7280';
const catDesc = categoryDesc[category] || `瀏覽所有「${category}」相關文章 — 餐飲SaaS出海實戰經驗分享。`;
const otherCategories = Object.entries(categoryMap).filter(([cat]) => cat !== category);
const pageTitle = `「${category}」文章列表`;
const pageDesc = `瀏覽所有「${category}」相關文章 — 餐飲SaaS出海實戰經驗，從中國香港走向全球市場。`;
---

<BlogLayout
  title={`${pageTitle} — 餐飲SaaS出海指南`}
  description={pageDesc}
  type="website"
>
  <!-- Category Hero -->
  <section class="bg-gradient-to-br from-blue-50 via-white to-emerald-50 border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <!-- Breadcrumb -->
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-blue-600 transition-colors mb-6"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        返回首頁
      </a>

      <!-- Category Badge + Title -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <span
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold shadow-sm"
            style={`background-color: ${catColor}18; color: ${catColor}; box-shadow: 0 0 0 1px ${catColor}30`}
          >
            <span class="w-2 h-2 rounded-full" style={`background-color: ${catColor}`}></span>
            {category}
          </span>
          <span class="text-sm text-gray-400 font-medium">
            {posts.length} 篇文章
          </span>
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight">
          {category}
        </h1>

        <p class="text-lg text-gray-600 leading-relaxed max-w-2xl">
          {catDesc}
        </p>
      </div>
    </div>
  </section>

  <!-- Post List -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {
      posts.length === 0 ? (
        <div class="text-center py-24 text-gray-500">
          <div class="text-6xl mb-4">📭</div>
          <p class="text-xl font-medium text-gray-700 mb-2">此分類暫無文章</p>
          <p class="text-gray-400 mb-6">我們正在準備更多「{category}」相關內容，敬請期待！</p>
          <a
            href={`${import.meta.env.BASE_URL}`}
            class="inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-blue-700 transition-colors"
          >
            ← 返回首頁
          </a>
        </div>
      ) : (
        <div class="grid gap-8">
          {posts.map((post) => (
            <article class="group bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-lg transition-all duration-300 overflow-hidden">
              <a
                href={`${import.meta.env.BASE_URL}blog/${post.slug}`}
                class="block p-6 sm:p-8"
              >
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-3">
                  <h2 class="text-xl sm:text-2xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug">
                    {post.data.title}
                  </h2>
                </div>

                <p class="text-gray-600 leading-relaxed mb-4">
                  {post.data.description}
                </p>

                <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
                  <time datetime={post.data.date.toISOString().split('T')[0]}>
                    {post.data.date.toLocaleDateString('zh-Hant', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </article>
          ))}
        </div>
      )
    }
  </section>

  <!-- 瀏覽其他主題 -->
  <section class="bg-gray-50 border-t border-gray-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <h2 class="text-xl font-bold text-gray-900 mb-6">瀏覽其他主題</h2>
      <div class="flex flex-wrap gap-3">
        {otherCategories.map(([cat, color]) => (
          <a
            href={`${import.meta.env.BASE_URL}category/${encodeURIComponent(cat)}`}
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium border cursor-pointer
                   hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
            style={`background-color: ${color}08; border-color: ${color}30; color: ${color}`}
          >
            <span class="w-2 h-2 rounded-full" style={`background-color: ${color}`}></span>
            {cat}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">
      有餐飲SaaS出海的經驗想分享？
    </h2>
    <p class="text-gray-600 mb-8 max-w-xl mx-auto">
      這是一個開放的知識庫。如果你也在餐飲科技行業打拼，歡迎交流討論。
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="https://github.com/foolcar/tappo-saas-blog"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-gray-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-800 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="inline-flex items-center gap-2 border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-50 transition-colors"
      >
        瀏覽全部文章
      </a>
    </div>
  </section>
</BlogLayout>
