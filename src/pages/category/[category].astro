---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((cat) => ({
    params: { category: cat },
  }));
};

const { category } = Astro.params;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter((p) => p.data.category === category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function estimateReadingTime(text: string): number {
  const cjkChars = (text.match(/[\u4e00-\u9fff\u3400-\u4dbf]/g) || []).length;
  const words = text.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil((cjkChars + words) / 400));
}

const categoryMap: Record<string, string> = {
  'POS選購': '#b85c3a',
  '全球市場': '#5a8a6a',
  '國際化': '#7c5aa8',
  '支付整合': '#c4893a',
  '合規挑戰': '#c44a4a',
  '產品設計': '#b84a7a',
  '團隊管理': '#4a6ab8',
};

const catDesc: Record<string, string> = {
  'POS選購': '如何在港澳市場選擇合適的餐飲 POS 系統？功能對比、價格分析、實施經驗 — 幫助餐飲老闆做出正確選擇。',
  '全球市場': '餐飲 SaaS 出海策略與市場分析：東南亞、歐美、中東等目標市場的機遇、挑戰與進入路徑。',
  '國際化': '多語言、多幣種、多時區 — 餐飲 SaaS 產品的國際化改造實戰筆記，從架構到測試全覆蓋。',
  '支付整合': '跨國支付通道對接實戰：Stripe、AlipayHK、PayMe、FPS 等，支付流程設計與合規考量。',
  '合規挑戰': 'GDPR、PDPO、數據跨境傳輸 — 餐飲 SaaS 出海路上的法規合規實戰與避坑指南。',
  '產品設計': '從用戶研究到產品迭代，餐飲 SaaS 的產品設計思維、方法論與實戰案例。',
  '團隊管理': '跨境遠端團隊協作、招聘策略、文化建設、績效管理 — 餐飲科技團隊的實戰經驗。',
};

const catColor = categoryMap[category] || '#6b6560';
const pageTitle = `「${category}」文章列表`;
const pageDesc = catDesc[category] || `瀏覽所有「${category}」相關文章 — 餐飲SaaS出海實戰經驗分享。`;
const otherCategories = Object.entries(categoryMap).filter(([cat]) => cat !== category);
const [featuredPost, ...restCategoryPosts] = posts;
---

<BlogLayout
  title={`${pageTitle} — 餐飲SaaS出海指南`}
  description={pageDesc}
  type="website"
>

  <!-- Category Hero ────────────────────────────── -->
  <section class="relative border-b border-[var(--color-border)] bg-[var(--color-surface)]">
    <!-- Accent bar at top -->
    <div class="h-1" style={`background-color: ${catColor}`}></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
      <!-- Breadcrumb -->
      <a
        href={import.meta.env.BASE_URL}
        class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)]
               hover:text-[var(--color-accent)] transition-colors mb-6"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        返回首頁
      </a>

      <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-4">
        <div>
          <div class="flex items-center gap-3 mb-3">
            <span
              class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-semibold"
              style={`background-color: ${catColor}12; color: ${catColor}`}
            >
              <span class="w-1.5 h-1.5 rounded-full" style={`background-color: ${catColor}`}></span>
              {category}
            </span>
            <span class="text-sm text-[var(--color-text-muted)]">
              {posts.length} 篇文章
            </span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-text)]">
            {category}
          </h1>
        </div>
      </div>

      <p class="mt-3 text-base sm:text-lg text-[var(--color-text-muted)] leading-relaxed max-w-2xl">
        {pageDesc}
      </p>
    </div>
  </section>

  <!-- Content ──────────────────────────────────── -->
  {
    posts.length === 0 ? (
      <!-- Empty state -->
      <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
        <div class="text-5xl mb-4 opacity-30" aria-hidden="true">—</div>
        <p class="text-xl font-semibold text-[var(--color-text)] mb-2">此分類暫無文章</p>
        <p class="text-sm text-[var(--color-text-muted)] mb-8">
          我們正在準備更多「{category}」相關內容，敬請期待！
        </p>
        <a
          href={import.meta.env.BASE_URL}
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium
                 bg-[var(--color-accent)] text-white
                 hover:opacity-90 transition-opacity"
        >
          ← 返回首頁
        </a>
      </section>
    ) : (
      <>
        <!-- Featured post (larger card) -->
        {featuredPost && (
          <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-14">
            <article
              class="group bg-[var(--color-surface)] rounded-xl border border-[var(--color-border)]
                     hover:border-[var(--color-accent-dim)] hover:shadow-md
                     transition-all duration-300 overflow-hidden"
            >
              <a href={`${import.meta.env.BASE_URL}blog/${featuredPost.slug}`} class="block p-6 sm:p-10">
                <div class="flex flex-wrap items-center gap-3 mb-4">
                  <span
                    class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold"
                    style={`background-color: ${catColor}15; color: ${catColor}`}
                  >
                    {category}
                  </span>
                  <span class="text-sm text-[var(--color-text-muted)]">
                    {estimateReadingTime(featuredPost.body)} 分鐘閱讀
                  </span>
                </div>

                <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text)]
                           group-hover:text-[var(--color-accent)] transition-colors duration-200
                           leading-tight mb-4 tracking-tight">
                  {featuredPost.data.title}
                </h2>

                <p class="text-base text-[var(--color-text-muted)] leading-relaxed mb-6 max-w-2xl">
                  {featuredPost.data.description}
                </p>

                <div class="flex flex-wrap items-center gap-4 text-sm">
                  <time datetime={featuredPost.data.date.toISOString().split('T')[0]} class="text-[var(--color-text-muted)]">
                    {featuredPost.data.date.toLocaleDateString('zh-Hant', {
                      year: 'numeric', month: 'long', day: 'numeric',
                    })}
                  </time>
                  <span class="text-[var(--color-accent)] font-medium group-hover:translate-x-1 transition-transform duration-200 inline-flex items-center gap-1">
                    閱讀全文
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </span>
                </div>
              </a>
            </article>
          </section>
        )}

        {/* Rest of posts — grid */}
        {restCategoryPosts.length > 0 && (
          <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-14">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)] mb-6">
              更多「{category}」文章
            </p>

            <div class="grid sm:grid-cols-2 gap-6">
              {restCategoryPosts.map((post) => (
                <article
                  class="group bg-[var(--color-surface)] rounded-xl border border-[var(--color-border)]
                         hover:border-[var(--color-accent-dim)] hover:shadow-md
                         transition-all duration-300"
                >
                  <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="block p-5 sm:p-6 h-full flex flex-col">
                    <div class="flex items-center gap-3 mb-3">
                      <span
                        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold shrink-0"
                        style={`background-color: ${catColor}15; color: ${catColor}`}
                      >
                        {category}
                      </span>
                      <span class="text-xs text-[var(--color-text-muted)]">
                        {estimateReadingTime(post.body)} 分鐘
                      </span>
                    </div>

                    <h3 class="text-lg font-bold text-[var(--color-text)]
                               group-hover:text-[var(--color-accent)] transition-colors duration-200
                               leading-snug mb-2 flex-1">
                      {post.data.title}
                    </h3>

                    <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3 line-clamp-2">
                      {post.data.description}
                    </p>

                    <div class="flex flex-wrap gap-2 mb-3">
                      {post.data.tags.slice(0, 3).map(tag => (
                        <span class="text-xs px-2 py-0.5 rounded bg-[var(--color-bg)] text-[var(--color-text-muted)]">
                          {tag}
                        </span>
                      ))}
                    </div>

                    <time datetime={post.data.date.toISOString().split('T')[0]} class="text-xs text-[var(--color-text-muted)]">
                      {post.data.date.toLocaleDateString('zh-Hant', {
                        year: 'numeric', month: 'long', day: 'numeric',
                      })}
                    </time>
                  </a>
                </article>
              ))}
            </div>
          </section>
        )}
      </>
    )
  }

  <!-- 瀏覽其他主題 ─────────────────────────────── -->
  {otherCategories.length > 0 && (
    <section class="bg-[var(--color-surface)] border-t border-[var(--color-border)] mt-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)] mb-6">
          瀏覽其他主題
        </p>

        <div class="flex flex-wrap gap-3">
          {otherCategories.map(([cat, color]) => (
            <a
              href={`${import.meta.env.BASE_URL}category/${encodeURIComponent(cat)}`}
              class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium
                     border transition-all duration-200
                     hover:-translate-y-0.5"
              style={`
                background-color: ${color}08;
                border-color: ${color}25;
                color: ${color};
              `}
            >
              <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${color}`}></span>
              {cat}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA ─────────────────────────────────────── -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-xl sm:text-2xl font-bold text-[var(--color-text)] mb-3">
      查看更多餐飲SaaS文章
    </h2>
    <p class="text-sm text-[var(--color-text-muted)] mb-8 max-w-md mx-auto leading-relaxed">
      探索七個主題分類，從技術架構到市場策略，全面覆蓋餐飲SaaS出海實戰。
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a
        href={import.meta.env.BASE_URL}
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium
               bg-[var(--color-text)] text-white
               hover:bg-[var(--color-accent)] transition-colors duration-200"
      >
        瀏覽全部文章
      </a>
      <a
        href={`${import.meta.env.BASE_URL}about`}
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium
               border border-[var(--color-border)] text-[var(--color-text-muted)]
               hover:border-[var(--color-accent-dim)] hover:text-[var(--color-accent)] transition-all duration-200"
      >
        關於阿公
      </a>
    </div>
  </section>

</BlogLayout>
