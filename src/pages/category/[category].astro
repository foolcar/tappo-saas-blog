---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((cat) => ({
    params: { category: cat },
  }));
};

const { category } = Astro.params;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter((p) => p.data.category === category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryMap: Record<string, { color: string; emoji: string; desc: string }> = {
  'POS選購':   { color: '#2563EB', emoji: '🖥️',  desc: '如何在港澳市場選擇合適的餐飲 POS 系統？功能對比、價格分析、實施經驗。' },
  '全球市場':  { color: '#059669', emoji: '🌏',  desc: '餐飲 SaaS 出海策略：東南亞、歐美、中東等市場機遇與挑戰。' },
  '國際化':    { color: '#7C3AED', emoji: '🌐',  desc: '多語言、多幣種、多時區 — 餐飲 SaaS 產品的國際化改造實戰。' },
  '支付整合':  { color: '#D97706', emoji: '💳',  desc: '跨國支付通道對接：Stripe、AlipayHK、PayMe 等實戰筆記。' },
  '合規挑戰':  { color: '#DC2626', emoji: '🛡️',  desc: 'GDPR、PDPO、數據跨境傳輸 — 出海路上的法規合規實戰。' },
  '產品設計':  { color: '#DB2777', emoji: '🎨',  desc: '從用戶研究到產品迭代，餐飲 SaaS 的產品設計思維與方法。' },
  '團隊管理':  { color: '#4F46E5', emoji: '👥',  desc: '跨境遠端團隊協作、招聘、文化建設的實戰經驗。' },
};

const cat = categoryMap[category] || { color: '#6B7280', emoji: '📂', desc: `瀏覽所有「${category}」相關文章。` };
const otherCategories = Object.entries(categoryMap).filter(([c]) => c !== category);
const pageTitle = `「${category}」文章列表`;
const pageDesc = cat.desc;

// Utility: lighten hex color for backgrounds
function tint(hex: string, opacity: number): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r}, ${g}, ${b}, ${opacity})`;
}

// Estimate reading time (Chinese: ~300 chars/min)
function readingTime(text: string): string {
  const chars = text.replace(/\s/g, '').length;
  const mins = Math.max(1, Math.round(chars / 300));
  return `${mins} 分鐘`;
}
---

<BlogLayout
  title={`${pageTitle} — 餐飲SaaS出海指南`}
  description={pageDesc}
  type="website"
>
  <!-- ═══════════════════ Category Hero ═══════════════════ -->
  <section
    class="relative overflow-hidden border-b"
    style={`background: linear-gradient(135deg, ${tint(cat.color, 0.06)} 0%, ${tint(cat.color, 0.02)} 50%, #ffffff 100%); border-color: ${tint(cat.color, 0.12)}`}
  >
    <!-- Subtle decorative bar at top -->
    <div class="absolute top-0 left-0 right-0 h-1" style={`background: linear-gradient(90deg, ${cat.color}, ${tint(cat.color, 0.3)})`}></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-18">
      <!-- Breadcrumb -->
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-700 transition-colors mb-6 group"
      >
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        <span>返回首頁</span>
      </a>

      <!-- Main hero content -->
      <div class="flex flex-col md:flex-row md:items-start gap-6">
        <!-- Emoji icon -->
        <div
          class="shrink-0 w-16 h-16 rounded-2xl flex items-center justify-center text-3xl shadow-sm"
          style={`background: ${tint(cat.color, 0.12)}`}
        >
          {cat.emoji}
        </div>

        <div class="flex-1">
          <!-- Category label -->
          <div class="flex items-center gap-3 mb-3">
            <span
              class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold tracking-wide"
              style={`background: ${tint(cat.color, 0.15)}; color: ${cat.color}`}
            >
              {category}
            </span>
            <span class="text-sm text-gray-400">
              {posts.length} 篇文章
            </span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight mb-3"
              style={`color: #111827`}>
            {category}
          </h1>

          <p class="text-lg leading-relaxed max-w-2xl" style={`color: #4B5563`}>
            {cat.desc}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ Article List ═══════════════════ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {
      posts.length === 0 ? (
        <!-- Empty state -->
        <div class="text-center py-24">
          <div class="text-6xl mb-4">{cat.emoji}</div>
          <p class="text-xl font-medium text-gray-700 mb-2">此分類暫無文章</p>
          <p class="text-gray-400 mb-8">我們正在準備更多「{category}」相關內容，敬請期待！</p>
          <a
            href={`${import.meta.env.BASE_URL}`}
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-medium text-white transition-colors hover:opacity-90"
            style={`background: ${cat.color}`}
          >
            ← 返回首頁
          </a>
        </div>
      ) : (
        <div class="space-y-6">
          {posts.map((post) => {
            const bodyText = post.body || '';
            const readTime = readingTime(bodyText);
            const postDate = post.data.date.toLocaleDateString('zh-Hant', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            return (
              <article class="group relative bg-white rounded-xl border border-gray-100 hover:border-gray-200 transition-all duration-300 overflow-hidden">
                {/* Left accent bar */}
                <div
                  class="absolute left-0 top-3 bottom-3 w-[3px] rounded-full opacity-60 group-hover:opacity-100 group-hover:top-2 group-hover:bottom-2 transition-all duration-300"
                  style={`background: ${cat.color}`}
                ></div>

                <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="block pl-7 pr-6 py-6 sm:pl-9 sm:pr-8 sm:py-7">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
                    <h2 class="text-xl sm:text-2xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug">
                      {post.data.title}
                    </h2>
                  </div>

                  <p class="text-gray-500 leading-relaxed mb-4 line-clamp-2">
                    {post.data.description}
                  </p>

                  <div class="flex flex-wrap items-center gap-3 text-sm text-gray-400">
                    <time datetime={post.data.date.toISOString().split('T')[0]} class="flex items-center gap-1.5">
                      <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                      {postDate}
                    </time>
                    <span class="flex items-center gap-1.5">
                      <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      {readTime}
                    </span>
                    {post.data.tags.length > 0 && (
                      <span class="hidden sm:block text-gray-300" aria-hidden="true">·</span>
                    )}
                    <div class="hidden sm:flex flex-wrap gap-1.5">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-500">
                          {tag}
                        </span>
                      ))}
                      {post.data.tags.length > 3 && (
                        <span class="text-xs text-gray-400">+{post.data.tags.length - 3}</span>
                      )}
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )
    }
  </section>

  <!-- ═══════════════════ 瀏覽其他主題 ═══════════════════ -->
  <section class="border-t" style={`border-color: ${tint('#E5E7EB', 0.6)}`}>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <h2 class="text-lg font-bold text-gray-900 mb-5">瀏覽其他主題</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {otherCategories.map(([c, info]) => (
          <a
            href={`${import.meta.env.BASE_URL}category/${encodeURIComponent(c)}`}
            class="flex items-center gap-3 px-4 py-3 rounded-xl border transition-all duration-200
                   hover:shadow-sm hover:-translate-y-0.5"
            style={`border-color: ${tint(info.color, 0.2)}; background: ${tint(info.color, 0.03)}`}
          >
            <span class="text-xl">{info.emoji}</span>
            <div class="flex flex-col">
              <span class="text-sm font-medium" style={`color: ${info.color}`}>{c}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════ CTA ═══════════════════ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <div
      class="rounded-2xl px-8 py-12"
      style={`background: ${tint(cat.color, 0.04)}; border: 1px solid ${tint(cat.color, 0.1)}`}
    >
      <h2 class="text-2xl font-bold text-gray-900 mb-3">
        有餐飲SaaS出海的經驗想分享？
      </h2>
      <p class="text-gray-500 mb-8 max-w-xl mx-auto leading-relaxed">
        這是一個開放的知識庫。如果你也在餐飲科技行業打拼，歡迎交流討論。
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="https://github.com/foolcar/tappo-saas-blog"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-gray-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-800 transition-colors shadow-sm"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href={`${import.meta.env.BASE_URL}`}
          class="inline-flex items-center gap-2 border border-gray-200 text-gray-600 px-6 py-3 rounded-lg font-medium hover:bg-white hover:border-gray-300 transition-colors"
        >
          瀏覽全部文章
        </a>
      </div>
    </div>
  </section>
</BlogLayout>
