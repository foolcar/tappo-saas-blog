---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((cat) => ({
    params: { category: cat },
  }));
};

const { category } = Astro.params;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter((p) => p.data.category === category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryMap: Record<string, { color: string; emoji: string; desc: string }> = {
  'POS選購':   { color: '#2563EB', emoji: '🖥️',  desc: '如何在港澳市場選擇合適的餐飲 POS 系統？功能對比、價格分析、實施經驗。' },
  '全球市場':  { color: '#059669', emoji: '🌏',  desc: '餐飲 SaaS 出海策略：東南亞、歐美、中東等市場機遇與挑戰。' },
  '國際化':    { color: '#7C3AED', emoji: '🌐',  desc: '多語言、多幣種、多時區 — 餐飲 SaaS 產品的國際化改造實戰。' },
  '支付整合':  { color: '#D97706', emoji: '💳',  desc: '跨國支付通道對接：Stripe、AlipayHK、PayMe 等實戰筆記。' },
  '合規挑戰':  { color: '#DC2626', emoji: '🛡️',  desc: 'GDPR、PDPO、數據跨境傳輸 — 出海路上的法規合規實戰。' },
  '產品設計':  { color: '#DB2777', emoji: '🎨',  desc: '從用戶研究到產品迭代，餐飲 SaaS 的產品設計思維與方法。' },
  '團隊管理':  { color: '#4F46E5', emoji: '👥',  desc: '跨境遠端團隊協作、招聘、文化建設的實戰經驗。' },
};

const cat = categoryMap[category] || { color: '#6B7280', emoji: '📂', desc: `瀏覽所有「${category}」相關文章。` };
const otherCategories = Object.entries(categoryMap).filter(([c]) => c !== category);
const pageTitle = `「${category}」文章列表`;
const pageDesc = cat.desc;
---

<BlogLayout
  title={`${pageTitle} — 餐飲SaaS出海指南`}
  description={pageDesc}
  type="website"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
      <a href={`${import.meta.env.BASE_URL}`} class="hover:text-blue-600 transition-colors">首頁</a>
      <span>/</span>
      <span class="font-medium text-gray-700">{cat.emoji} {category}</span>
      <span class="text-gray-300">· {posts.length} 篇</span>
    </nav>

    <!-- Page heading -->
    <h1 class="text-2xl font-bold text-gray-900 mb-2">{category}</h1>
    <p class="text-gray-500 mb-10">{cat.desc}</p>

    <!-- Article list -->
    {
      posts.length === 0 ? (
        <div class="text-center py-16 text-gray-400">
          <p>此分類暫無文章，敬請期待。</p>
          <a href={`${import.meta.env.BASE_URL}`} class="text-blue-600 hover:underline mt-4 inline-block">← 返回首頁</a>
        </div>
      ) : (
        <div class="space-y-4">
          {posts.map((post) => {
            const postDate = post.data.date.toLocaleDateString('zh-Hant', {
              year: 'numeric', month: 'short', day: 'numeric',
            });
            return (
              <article class="border-l-4 border-gray-200 hover:border-blue-400 pl-4 py-1 transition-colors">
                <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="block group">
                  <h2 class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug">
                    {post.data.title}
                  </h2>
                  <p class="text-sm text-gray-500 mt-1 leading-relaxed">
                    {post.data.description}
                  </p>
                  <div class="flex flex-wrap items-center gap-3 mt-2 text-xs text-gray-400">
                    <time datetime={post.data.date.toISOString().split('T')[0]}>{postDate}</time>
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="bg-gray-50 px-1.5 py-0.5 rounded">{tag}</span>
                    ))}
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )
    }

    <!-- Other categories -->
    <div class="mt-16 pt-8 border-t border-gray-100">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">瀏覽其他主題</h3>
      <div class="flex flex-wrap gap-2">
        {otherCategories.map(([c, info]) => (
          <a href={`${import.meta.env.BASE_URL}category/${encodeURIComponent(c)}`}
             class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-sm border border-gray-200 text-gray-600
                    hover:border-blue-300 hover:text-blue-600 hover:bg-blue-50 transition-colors">
            <span>{info.emoji}</span> {c}
          </a>
        ))}
      </div>
    </div>
  </div>
</BlogLayout>
