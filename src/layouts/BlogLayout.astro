---
// BlogLayout.astro - 博客布局组件，带 SEO meta、导航、页脚
import type { PropsWithChildren } from 'react';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  date?: Date;
  updated?: Date;
  category?: string;
  tags?: string[];
  slug?: string;
  wordCount?: number;
  breadcrumbs?: { name: string; url?: string }[];
  locale?: 'zh-Hant' | 'en';
  alternateUrl?: string; // URL of alternate language version (for hreflang)
  enSlug?: string; // English slug for language toggle (for non-blog pages that have EN versions)
  zhSlug?: string; // Chinese slug for language toggle
}

const {
  title,
  description,
  image = '/og-default.png',
  type = 'website',
  date,
  updated,
  category,
  tags = [],
  slug,
  wordCount,
  breadcrumbs,
  locale = 'zh-Hant',
  alternateUrl,
  enSlug,
  zhSlug,
} = Astro.props;

const siteTitle = locale === 'en' ? 'F&B SaaS Going Global Guide' : '餐飲SaaS出海指南';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const siteUrl = Astro.site?.origin ?? 'https://blog.foolcar.cc';
const basePath = siteUrl;
const pageUrl = Astro.url.toString();
const imageUrl = image.startsWith('http') ? image : `${basePath}${image}`;

// Compute language toggle URL
const langToggleUrl = alternateUrl
  ? alternateUrl  // explicit override (e.g. about page)
  : locale === 'en'
    ? (zhSlug ? `${basePath}/blog/${zhSlug}/` : `${basePath}/`)
    : (enSlug ? `${basePath}/en/blog/${enSlug}/` : `${basePath}/en/`);
---

<!DOCTYPE html>
<html lang={locale === 'en' ? 'en' : 'zh-Hant'}>
<head>
  <meta charset="UTF-8" />
  <meta name="google-site-verification" content="D68PPCqBjgUyTa5SWCl5o2OjkMg9jFDP7hTvPfltgRM" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary Meta -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content="阿公" />
  <link rel="canonical" href={pageUrl} />

  <!-- Hreflang — auto-generated from props -->
  {
    (() => {
      const zhHref = locale === 'zh-Hant'
        ? pageUrl
        : (alternateUrl || (slug && zhSlug ? `${basePath}/blog/${zhSlug}/` : null));
      const enHref = locale === 'en'
        ? pageUrl
        : (alternateUrl || (slug && enSlug ? `${basePath}/en/blog/${enSlug}/` : null));

      if (zhHref && enHref) {
        return <>
          <link rel="alternate" hreflang="zh-Hant" href={zhHref} />
          <link rel="alternate" hreflang="en" href={enHref} />
          <link rel="alternate" hreflang="x-default" href={zhHref} />
        </>;
      }
      return null;
    })()
  }

  <!-- Lang toggle button style -->
  <style>
    .lang-active {
      background-color: #3B82F6 !important;
      color: white !important;
    }
  </style>

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={imageUrl} />
  <meta property="og:site_name" content={siteTitle} />
  <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'zh_Hant'} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  {
    type === 'article' && date ? (
      <>
        <meta property="article:published_time" content={date.toISOString()} />
        <meta property="article:modified_time" content={(updated || date).toISOString()} />
        <meta property="article:author" content="阿公" />
        {category && <meta property="article:section" content={category} />}
        {tags.map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    ) : null
  }

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageUrl} />

  <!-- BreadcrumbList Structured Data -->
  {
    breadcrumbs && breadcrumbs.length > 0 ? (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((b, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: b.name,
          ...(b.url ? { item: b.url } : {}),
        })),
      })} />
    ) : null
  }

  <!-- Structured Data -->
  {
    type === 'article' ? (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description: description,
        image: imageUrl,
        datePublished: date?.toISOString(),
        dateModified: (updated || date)?.toISOString(),
        inLanguage: locale === 'en' ? 'en' : 'zh-Hant',
        author: {
          '@type': 'Person',
          name: '阿公',
          url: 'https://blog.foolcar.cc',
        },
        publisher: {
          '@type': 'Organization',
          name: siteTitle,
        },
        url: pageUrl,
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': pageUrl,
        },
        ...(category ? { articleSection: category } : {}),
        ...(tags.length > 0 ? { keywords: tags.join(', ') } : {}),
        ...(wordCount ? { wordCount } : {}),
      })} />
    ) : (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: siteTitle,
        url: siteUrl,
        description: description,
        inLanguage: locale === 'en' ? 'en' : 'zh-Hant',
        author: {
          '@type': 'Person',
          name: '阿公',
          url: 'https://blog.foolcar.cc',
        },
      })} />
    )
  }

  <!-- Preconnect to Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RPXX86P33G"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-RPXX86P33G');
  </script>

  <!-- Ahrefs Analytics -->
  <script src="https://analytics.ahrefs.com/analytics.js" data-key="gkivmb3fm+jULNp4i0mgkw" async></script>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen flex flex-col">
  <!-- Reading progress bar (article pages only) -->
  {type === 'article' && (
    <div id="reading-progress" class="fixed top-0 left-0 z-[60] h-[3px] bg-gradient-to-r from-blue-500 to-blue-600 transition-all duration-150" style="width: 0%"></div>
  )}

  <!-- 导航栏 -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100">
    <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-2 group" aria-label={locale === 'en' ? 'Home' : '首页'}>
          <span class="text-2xl" role="img" aria-hidden="true">🍜</span>
          <span class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
            {locale === 'en' ? 'F&B SaaS Going Global' : '餐飲SaaS出海指南'}
          </span>
        </a>
        <div class="flex items-center gap-6">
          <a href={`${import.meta.env.BASE_URL}`} class="text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors">
            {locale === 'en' ? 'Articles' : '文章'}
          </a>
          <a href={`${import.meta.env.BASE_URL}about`} class="text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors">
            {locale === 'en' ? 'About' : '關於'}
          </a>
          <!-- Language Toggle -->
          <a
            href={langToggleUrl}
            class="flex items-center gap-1 text-xs font-semibold border border-gray-300 rounded-full px-2.5 py-1 hover:border-blue-500 hover:text-blue-600 transition-colors"
            aria-label={locale === 'en' ? '切換到中文' : 'Switch to English'}
          >
            <span class={locale === 'zh-Hant' ? 'text-blue-600 font-bold' : 'text-gray-400'}>中</span>
            <span class="text-gray-300">/</span>
            <span class={locale === 'en' ? 'text-blue-600 font-bold' : 'text-gray-400'}>EN</span>
          </a>
        </div>
      </div>
    </nav>
  </header>

  <!-- 主内容区 -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- 页脚 -->
  <footer class="bg-gray-50 border-t border-gray-200 mt-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-gray-500 text-sm">
          <span class="text-lg" role="img" aria-hidden="true">🍜</span>
          <span>{siteTitle} © {new Date().getFullYear()}</span>
        </div>
        <div class="flex items-center gap-6">
          <a href={`${import.meta.env.BASE_URL}`} class="text-sm text-gray-500 hover:text-gray-700 transition-colors">{locale === 'en' ? 'Articles' : '文章'}</a>
          <a href={`${import.meta.env.BASE_URL}tags`} class="text-sm text-gray-500 hover:text-gray-700 transition-colors">{locale === 'en' ? 'Tags' : '標籤'}</a>
          <a href={`${import.meta.env.BASE_URL}about`} class="text-sm text-gray-500 hover:text-gray-700 transition-colors">{locale === 'en' ? 'About' : '關於'}</a>
          <a href={`${siteUrl}/sitemap.xml`} class="text-sm text-gray-500 hover:text-gray-700 transition-colors">Sitemap</a>
        </div>
      </div>
      <p class="text-center text-xs text-gray-400 mt-6">
        {locale === 'en' ? (
          <>By <a href="https://blog.foolcar.cc" class="text-gray-500 hover:text-blue-600 transition-colors">Ah Gung</a> — Sharing real-world F&B SaaS experience from Hong Kong to the global market</>
        ) : (
          <>由 <a href="https://blog.foolcar.cc" class="text-gray-500 hover:text-blue-600 transition-colors">阿公</a> 撰寫 — 分享餐飲SaaS從中國香港走向全球的實戰經驗</>
        )}
      </p>
    </div>
  </footer>

  <!-- Back to top button -->
  <button id="back-to-top"
    class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full bg-blue-600 text-white shadow-lg
           opacity-0 translate-y-2 pointer-events-none transition-all duration-300
           hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2"
    aria-label={locale === 'en' ? 'Back to top' : '返回頂部'}
    title={locale === 'en' ? 'Back to top' : '返回頂部'}>
    <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
    </svg>
  </button>

  <!-- Reading progress & back-to-top JS -->
  <script>
    // Reading progress bar
    const progressBar = document.getElementById('reading-progress');
    if (progressBar) {
      window.addEventListener('scroll', () => {
        const winScroll = document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
        progressBar.style.width = scrolled + '%';
      }, { passive: true });
    }

    // Back to top button
    const backToTop = document.getElementById('back-to-top');
    if (backToTop) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) {
          backToTop.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
        } else {
          backToTop.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
        }
      }, { passive: true });

      backToTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  </script>

  <!-- Google Fonts -->
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
  </style>
</body>
</html>
