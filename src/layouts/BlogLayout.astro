---
// BlogLayout.astro — 博客全局佈局
// 含 SEO meta、導航、閱讀進度條、頁腳、返回頂部
import type { PropsWithChildren } from 'react';

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  date?: Date;
  updated?: Date;
  category?: string;
  tags?: string[];
  slug?: string;
  wordCount?: number;
}

const {
  title,
  description,
  image = '/og-default.svg',
  type = 'website',
  date,
  updated,
  category,
  tags = [],
  slug,
  wordCount,
} = Astro.props;

const siteTitle = '餐饮SaaS出海指南';
const fullTitle = type === 'article' ? title : `${title} | ${siteTitle}`;
const siteUrl = Astro.site?.origin ?? '';
const pageUrl = slug ? `${siteUrl}/tappo-saas-blog/blog/${slug}` : `${siteUrl}/tappo-saas-blog`;
const imageUrl = image.startsWith('http') ? image : `${siteUrl}/tappo-saas-blog${image}`;
const isArticle = type === 'article';
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary Meta -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content="阿公" />
  <link rel="canonical" href={pageUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={imageUrl} />
  <meta property="og:site_name" content={siteTitle} />
  <meta property="og:locale" content="zh_Hant" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  {
    isArticle && date ? (
      <>
        <meta property="article:published_time" content={date.toISOString()} />
        <meta property="article:modified_time" content={(updated || date).toISOString()} />
        <meta property="article:author" content="阿公" />
        {category && <meta property="article:section" content={category} />}
        {tags.map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    ) : null
  }

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageUrl} />

  <!-- Structured Data -->
  {
    isArticle ? (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description: description,
        image: imageUrl,
        datePublished: date?.toISOString(),
        dateModified: (updated || date)?.toISOString(),
        inLanguage: 'zh-Hant',
        author: {
          '@type': 'Person',
          name: '阿公',
          url: 'https://foolcar.github.io',
        },
        publisher: {
          '@type': 'Organization',
          name: siteTitle,
        },
        url: pageUrl,
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': pageUrl,
        },
        ...(category ? { articleSection: category } : {}),
        ...(tags.length > 0 ? { keywords: tags.join(', ') } : {}),
        ...(wordCount ? { wordCount } : {}),
      })} />
    ) : (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: siteTitle,
        url: `${siteUrl}/tappo-saas-blog`,
        description: description,
        inLanguage: 'zh-Hant',
        author: {
          '@type': 'Person',
          name: '阿公',
          url: 'https://foolcar.github.io',
        },
      })} />
    )
  }

  <!-- Preconnect Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen flex flex-col bg-[var(--color-bg)]">

  <!-- Reading Progress Bar (article pages only) -->
  {isArticle && <div class="reading-progress" id="reading-progress"></div>}

  <!-- 導航欄 ──────────────────────────────── -->
  <header class="sticky top-0 z-50 bg-[var(--color-bg)]/92 backdrop-blur-md border-b border-[var(--color-border)]">
    <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14 sm:h-16">

        <!-- Logo -->
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 group" aria-label="首頁">
          <span class="text-lg sm:text-xl font-bold tracking-tight text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200">
            {siteTitle}
          </span>
        </a>

        <!-- Nav links -->
        <div class="flex items-center gap-1 sm:gap-2">
          <a
            href={import.meta.env.BASE_URL}
            class="px-3 py-1.5 text-sm font-medium rounded-md text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-accent-soft)] transition-all duration-200"
          >
            文章
          </a>
          <a
            href={`${import.meta.env.BASE_URL}about`}
            class="px-3 py-1.5 text-sm font-medium rounded-md text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-accent-soft)] transition-all duration-200"
          >
            關於
          </a>
        </div>
      </div>
    </nav>
  </header>

  <!-- 主內容 ───────────────────────────────── -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- 頁腳 ─────────────────────────────────── -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)] mt-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">

        <!-- Brand -->
        <div>
          <p class="text-sm font-bold text-[var(--color-text)] mb-2">{siteTitle}</p>
          <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
            分享餐飲SaaS從中國香港走向全球的實戰經驗
          </p>
        </div>

        <!-- Navigation -->
        <div>
          <p class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">導覽</p>
          <div class="flex flex-col gap-2">
            <a href={import.meta.env.BASE_URL} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">所有文章</a>
            <a href={`${import.meta.env.BASE_URL}about`} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">關於阿公</a>
            <a href="/tappo-saas-blog/rss.xml" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">RSS 訂閱</a>
            <a href="/tappo-saas-blog/sitemap-index.xml" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">網站地圖</a>
          </div>
        </div>

        <!-- External -->
        <div>
          <p class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">連結</p>
          <div class="flex flex-col gap-2">
            <a
              href="https://github.com/foolcar/tappo-saas-blog"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
            >
              GitHub
            </a>
            <a
              href="https://foolcar.github.io"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
            >
              個人主頁
            </a>
          </div>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-[var(--color-border)]">
        <p class="text-xs text-center text-[var(--color-text-muted)]">
          由 <a href="https://foolcar.github.io" class="text-[var(--color-accent)] hover:underline">阿公</a> 撰寫 &copy; {new Date().getFullYear()}
          &mdash; 20多年中港兩地工作，30多年互聯網產品探索經驗
        </p>
      </div>
    </div>
  </footer>

  <!-- 返回頂部按鈕 ────────────────────────── -->
  <button
    id="back-to-top"
    aria-label="返回頂部"
    class="fixed bottom-6 right-6 z-40 w-10 h-10 rounded-full
           bg-[var(--color-surface)] border border-[var(--color-border)]
           shadow-md text-[var(--color-text-muted)]
           hover:text-[var(--color-accent)] hover:border-[var(--color-accent-dim)]
           opacity-0 pointer-events-none translate-y-2
           transition-all duration-300 flex items-center justify-center"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
    </svg>
  </button>

  <!-- Scripts ───────────────────────────────── -->
  <script is:inline>
    // Reading progress bar
    (function() {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;

      function update() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        bar.style.width = Math.min(pct, 100) + '%';
      }

      window.addEventListener('scroll', update, { passive: true });
      update();
    })();

    // Back to top
    (function() {
      const btn = document.getElementById('back-to-top');
      if (!btn) return;

      function toggle() {
        const show = window.scrollY > 400;
        btn.classList.toggle('opacity-0', !show);
        btn.classList.toggle('pointer-events-none', !show);
        btn.classList.toggle('translate-y-2', !show);
      }

      window.addEventListener('scroll', toggle, { passive: true });
      btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      toggle();
    })();
  </script>

  <!-- Google Fonts -->
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=Noto+Serif+TC:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
  </style>
</body>
</html>
